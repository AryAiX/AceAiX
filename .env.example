# ROOT secrets — server-side / CLI / admin only. Copy to .env and fill in. Never commit real values.
SUPABASE_PROJECT_REF=your_project_ref
SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_ANON_KEY=eyJ...            # legacy anon JWT (optional)
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # SECRET — bypasses RLS, server-side only
SUPABASE_DB_PASSWORD=your_db_password
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.your_project_ref.supabase.co:5432/postgres
